{
  "name": "@economic/backend",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./src/*": {
      "import": "./src/*",
      "types": "./src/*"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@economic/core": "workspace:*",
    "@economic/executor": "workspace:*",
    "@fastify/cors": "8.5.0",
    "fastify": "^4.24.0",
    "vm2": "^3.9.19",
    "better-sqlite3": "^9.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "tsx": "^4.0.0",
    "vitest": "^1.0.0",
    "@types/better-sqlite3": "^7.6.0"
  }
}